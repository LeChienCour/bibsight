# Bibsight environment variables — copy to .env and adjust

# YOLO
RPT_YOLO_MODEL=yolov8n.pt
RPT_YOLO_CONF_PERSON=0.5

# InsightFace
RPT_INSIGHTFACE_MODEL=buffalo_l
RPT_INSIGHTFACE_CTX_ID=0

# OCR
RPT_OCR_MIN_CONF=0.7

# I/O
RPT_INPUT_DIR=data/images
RPT_OUTPUT_DIR=results

# Video — procesar 1 de cada N frames
RPT_VIDEO_FRAME_STEP=5

# Compute
RPT_DEVICE=cuda
